{
  "appId": "com.removiewer2.server",
  "productName": "RemoViewer2Server",
  "artifactName": "${productName}-${version}-portable.${ext}",
  "directories": {
    "output": "release"
  },
  "files": [
    "src/**/*",
    "assets/**/*"
  ],
  "asarUnpack": [
    "**/*.node",
    "**/node_modules/sharp/**",
    "**/node_modules/@img/**"
  ],
  "win": {
    "target": ["nsis", "zip"],
    "icon": "assets/icon.ico"
  },
  "compression": "store",
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico",
    "artifactName": "${productName}-${version}-setup.exe"
  },
  "npmRebuild": true,
  "electronLanguages": ["ko", "en-US"],
  "afterPack": "./afterPack.js"
}
